import { useState, useCallback, useEffect, useRef } from "react";
import { Upload, Camera, ImageIcon, Sparkles, X, RefreshCw } from "lucide-react";
import { useIsMobile } from "@/hooks/use-mobile";
import { toast } from "@/hooks/use-toast";

interface PhotoUploadProps {
  onPhotoSelected: (file: File, preview: string) => void;
}

const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB
const ALLOWED_TYPES = ["image/jpeg", "image/png", "image/webp", "image/heic", "image/heif"];

function compressImage(file: File, maxDim = 1920): Promise<File> {
  return new Promise((resolve) => {
    if (file.size <= MAX_FILE_SIZE) { resolve(file); return; }
    const img = new Image();
    img.onload = () => {
      const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
      const canvas = document.createElement("canvas");
      canvas.width = img.width * scale;
      canvas.height = img.height * scale;
      canvas.getContext("2d")!.drawImage(img, 0, 0, canvas.width, canvas.height);
      canvas.toBlob(
        (blob) => resolve(blob ? new File([blob], file.name, { type: "image/jpeg" }) : file),
        "image/jpeg",
        0.82
      );
    };
    img.onerror = () => resolve(file);
    img.src = URL.createObjectURL(file);
  });
}

const PhotoUpload = ({ onPhotoSelected }: PhotoUploadProps) => {
  const [dragActive, setDragActive] = useState(false);
  const [preview, setPreview] = useState<string | null>(null);
  const [selectedFile, setSelectedFile] = useState<File | null>(null);
  const [showScan, setShowScan] = useState(false);
  const isMobile = useIsMobile();
  const cameraRef = useRef<HTMLInputElement>(null);
  const galleryRef = useRef<HTMLInputElement>(null);
  const dropRef = useRef<HTMLInputElement>(null);

  useEffect(() => {
    if (!localStorage.getItem("ai_seen")) {
      setShowScan(true);
      localStorage.setItem("ai_seen", "true");
      const t = setTimeout(() => setShowScan(false), 2000);
      return () => clearTimeout(t);
    }
  }, []);

  const processFile = useCallback(async (file: File) => {
    if (!file.type.startsWith("image/") && !ALLOWED_TYPES.includes(file.type)) {
      toast({ title: "Invalid file", description: "Please upload a JPG, PNG, or WebP image.", variant: "destructive" });
      return;
    }
    if (file.size > MAX_FILE_SIZE * 2) {
      toast({ title: "File too large", description: "Please use an image under 10MB.", variant: "destructive" });
      return;
    }
    const compressed = await compressImage(file);
    const reader = new FileReader();
    reader.onload = (e) => {
      const url = e.target?.result as string;
      setPreview(url);
      setSelectedFile(compressed);
      onPhotoSelected(compressed, url);
    };
    reader.readAsDataURL(compressed);
  }, [onPhotoSelected]);

  const handleDrag = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setDragActive(e.type === "dragenter" || e.type === "dragover");
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setDragActive(false);
    if (e.dataTransfer.files?.[0]) processFile(e.dataTransfer.files[0]);
  };

  const handleClear = () => {
    setPreview(null);
    setSelectedFile(null);
    if (cameraRef.current) cameraRef.current.value = "";
    if (galleryRef.current) galleryRef.current.value = "";
    if (dropRef.current) dropRef.current.value = "";
  };

  // If preview is shown, display it with replace/remove
  if (preview && selectedFile) {
    return (
      <div className="space-y-6">
        <div className="text-center space-y-2">
          <h2 className="font-display text-2xl md:text-3xl font-bold text-foreground">
            Your Photo
          </h2>
          <p className="text-muted-foreground text-sm">Looking good! Continue to customize your renovation.</p>
        </div>
        <div className="relative rounded-xl overflow-hidden border border-border max-w-lg mx-auto">
          <img src={preview} alt="Room preview" className="w-full h-auto max-h-[400px] object-contain bg-muted" />
          <div className="absolute top-3 right-3 flex gap-2">
            <button
              onClick={handleClear}
              className="p-2 rounded-full bg-background/80 backdrop-blur border border-border text-foreground hover:bg-destructive hover:text-destructive-foreground transition-colors"
              aria-label="Remove photo"
            >
              <X size={18} />
            </button>
          </div>
        </div>
        <div className="flex justify-center">
          <button
            onClick={handleClear}
            className="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            <RefreshCw size={14} />
            Choose a different photo
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <style>{`
        .ai-upload-box {
          position: relative;
          overflow: hidden;
          transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .ai-upload-box:hover {
          transform: scale(1.02);
          box-shadow: 0 0 0 2px hsl(var(--accent) / 0.3), 0 10px 30px hsl(var(--accent) / 0.15);
          border-color: hsl(var(--accent)) !important;
        }
        .ai-upload-box.drag-active {
          transform: scale(1.02);
          box-shadow: 0 0 0 2px hsl(var(--accent) / 0.4), 0 10px 30px hsl(var(--accent) / 0.2);
          border-color: hsl(var(--accent)) !important;
          background: hsl(var(--accent) / 0.05);
        }
        @keyframes ai-icon-pulse {
          0%, 100% { transform: scale(1); opacity: 1; }
          50% { transform: scale(1.08); opacity: 0.7; }
        }
        .ai-icon-pulse { animation: ai-icon-pulse 2s ease-in-out infinite; }
        @keyframes ai-scan-sweep {
          from { left: -100%; }
          to { left: 100%; }
        }
        .ai-scan-overlay {
          position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
          background: linear-gradient(90deg, transparent, hsl(var(--accent) / 0.25), transparent);
          animation: ai-scan-sweep 1.5s ease forwards;
          pointer-events: none; z-index: 5;
        }
        .ai-hover-hint { opacity: 0; transition: opacity 0.3s ease; }
        .ai-upload-box:hover .ai-hover-hint { opacity: 1; }
        @media (max-width: 640px) { .ai-scan-overlay { display: none; } }
      `}</style>

      <div className="text-center space-y-2">
        <div className="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent/10">
          <Camera size={32} className="text-accent" />
        </div>
        <h2 className="font-display text-2xl md:text-3xl font-bold text-foreground">
          Upload Your Space
        </h2>
        <p className="text-muted-foreground max-w-md mx-auto">
          Take a photo of any room and see what it could look like after a professional renovation.
        </p>
      </div>

      {/* Hidden file inputs */}
      <input
        ref={cameraRef}
        type="file"
        accept="image/*"
        capture="environment"
        className="hidden"
        onChange={(e) => e.target.files?.[0] && processFile(e.target.files[0])}
      />
      <input
        ref={galleryRef}
        type="file"
        accept="image/jpeg,image/png,image/webp,image/heic,image/heif"
        className="hidden"
        onChange={(e) => e.target.files?.[0] && processFile(e.target.files[0])}
      />

      {/* Mobile: two large buttons */}
      {isMobile && (
        <div className="grid grid-cols-1 gap-3">
          <button
            onClick={() => cameraRef.current?.click()}
            className="flex items-center justify-center gap-3 w-full py-5 px-6 rounded-xl bg-accent text-accent-foreground font-display font-semibold text-lg transition-transform active:scale-[0.97]"
          >
            <Camera size={24} />
            Take Photo
          </button>
          <button
            onClick={() => galleryRef.current?.click()}
            className="flex items-center justify-center gap-3 w-full py-5 px-6 rounded-xl border-2 border-accent bg-accent/5 text-accent font-display font-semibold text-lg transition-transform active:scale-[0.97]"
          >
            <ImageIcon size={24} />
            Upload from Gallery
          </button>
        </div>
      )}

      {/* Desktop: drag & drop zone + small buttons */}
      {!isMobile && (
        <>
          <div className="flex gap-3 justify-center">
            <button
              onClick={() => cameraRef.current?.click()}
              className="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border bg-muted hover:bg-accent/10 hover:border-accent text-foreground text-sm font-medium transition-colors"
            >
              <Camera size={16} />
              Take Photo
            </button>
            <button
              onClick={() => galleryRef.current?.click()}
              className="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border bg-muted hover:bg-accent/10 hover:border-accent text-foreground text-sm font-medium transition-colors"
            >
              <ImageIcon size={16} />
              Browse Files
            </button>
          </div>

          <label
            className={`ai-upload-box block border-2 border-dashed rounded-xl p-12 md:p-16 text-center cursor-pointer ${
              dragActive ? "drag-active" : "border-border"
            }`}
            onDragEnter={handleDrag}
            onDragLeave={handleDrag}
            onDragOver={handleDrag}
            onDrop={handleDrop}
          >
            {showScan && <div className="ai-scan-overlay" />}
            <input
              ref={dropRef}
              type="file"
              accept="image/jpeg,image/png,image/webp,image/heic,image/heif"
              className="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
              onChange={(e) => e.target.files?.[0] && processFile(e.target.files[0])}
            />
            <div className="space-y-4 relative z-10">
              <div className="inline-flex items-center justify-center w-14 h-14 rounded-full bg-muted ai-icon-pulse">
                <Upload size={24} className="text-muted-foreground" />
              </div>
              <div>
                <p className="font-display font-semibold text-foreground text-lg">
                  Drag & drop your photo here
                </p>
                <p className="text-sm text-muted-foreground mt-1">
                  or click to browse files
                </p>
              </div>
              <div className="flex items-center justify-center gap-3 text-xs text-muted-foreground">
                <ImageIcon size={14} />
                <span>JPG, PNG, WebP • Max 5MB</span>
              </div>
            </div>
            <div className="ai-hover-hint absolute bottom-3 left-0 right-0 flex justify-center pointer-events-none z-10">
              <span className="inline-flex items-center gap-1.5 text-[11px] text-accent font-medium bg-accent/5 px-3 py-1 rounded-full">
                <Sparkles size={10} />
                AI-powered preview
              </span>
            </div>
          </label>
        </>
      )}

      <p className="text-center text-xs text-muted-foreground/70">
        Upload a room photo to preview the transformation
      </p>

      <div className="grid grid-cols-3 gap-3 text-center">
        {["Kitchen", "Bathroom", "Living Room"].map((room) => (
          <div key={room} className="p-3 rounded-lg bg-muted/50 border border-border">
            <p className="text-xs text-muted-foreground font-medium">{room}</p>
          </div>
        ))}
      </div>
    </div>
  );
};

export default PhotoUpload;
