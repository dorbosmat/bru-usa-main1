# ======================================================================
# Build Right USA — Frontend Environment Variables
# ======================================================================
# Copy this file to .env and fill in the values.
# These are PUBLIC (client-side) variables — never put secrets here.
# ======================================================================

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Cloudflare Turnstile site key (Sprint Task 6 scaffolding).
# PUBLIC by design — ships in the client bundle.
# While unset, src/hooks/useTurnstile.ts returns a dev-bypass token and
# the server-side verifier soft-passes, so dev keeps working. Provision
# a real Turnstile key before re-enabling lead submission.
VITE_TURNSTILE_SITE_KEY=""

# ======================================================================
# Backend secrets — set in Supabase Dashboard → Edge Functions → Secrets
# NEVER put these in .env or commit them to git
# ======================================================================
# LOVABLE_API_KEY            — Lovable AI Gateway (chat + ai-renovation)
# RESEND_API_KEY             — Resend email notifications
# ALLOWED_ORIGIN             — Legacy; the chat function now uses an
#                              inline allowlist in supabase/functions/
#                              chat/index.ts. Safe to remove.
# TURNSTILE_SECRET_KEY       — Cloudflare Turnstile server-side secret
#                              (required by supabase/functions/_shared/
#                              turnstile.ts). While unset, helper returns
#                              valid: true with reason "dev-bypass-no-
#                              secret" — safe for dev/preview.
# ENFORCE_RATE_LIMIT         — Set to "1" to flip the persistent rate
#                              limiter from observe-only ("shadow mode")
#                              to enforcing. Leave unset until a week of
#                              abuse_events data is reviewed.
